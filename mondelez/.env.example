# Mondelez project — connection env (template)
#
# Copy file này thành .env (cùng thư mục) rồi điền các giá trị trống.
# .env KHÔNG commit (đã có trong .gitignore); file .example này thì committed.

# --- ClickHouse (analytics_workspace, cùng cluster Panasonic) ---
CLICKHOUSE_HOST=ghrx9lirdl.ap-southeast-1.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_DATABASE=analytics_workspace
CLICKHOUSE_USER=helix
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true

# --- Google Sheets export ---
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SHEET_ID=

# --- Smartlog TMS (STM) — tải report; flow: knowledge-base/tms/_shared/auth.md ---
TMS_AUTH_URL=https://auth-be.smartlogvn.com/connect/token
TMS_REPORT_HOST=https://api-stm-prod-report.smartlogvn.com
# header `d:` gửi kèm mỗi request report
TMS_TENANT_HOST=mondelez.smartlogvn.com
TMS_CLIENT_ID=STM
TMS_SCOPE=openid profile email address phone role Auth offline_access
# vd helixbi.mdlz@gosmartlog.com
TMS_USERNAME=
TMS_PASSWORD=

# --- Smartlog WMS — tải report (host TBD) ---
WMS_AUTH_URL=
WMS_REPORT_HOST=
WMS_TENANT_HOST=mondelez.smartlogvn.com
WMS_CLIENT_ID=
WMS_USERNAME=
WMS_PASSWORD=
