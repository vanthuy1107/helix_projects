# Panasonic project — ClickHouse connection
#
# Cùng cluster với Mondelez (analytics_workspace). Có 2 cách dùng:
#   1. Copy file này thành .env và điền password
#   2. Để trống file này, runner sẽ fallback sang projects/mondelez/.env
#
# KHÔNG commit .env (đã có trong .gitignore)

CLICKHOUSE_HOST=ghrx9lirdl.ap-southeast-1.aws.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_DATABASE=analytics_workspace
CLICKHOUSE_USER=helix
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=true
